{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "/blog",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-error",
          "value": "NOT_FOUND"
        }
      ],
      "permanent": false
    },
    {
      "source": "/en/:path*",
      "destination": "/en/blog",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-error",
          "value": "NOT_FOUND"
        }
      ],
      "permanent": false
    }
  ]
}