---
import { Image } from "@astrojs/image/components";
import { t } from "i18next";
import avatarImage from "../assets/avatar.webp";
---

<div class="flex flex-col items-center gap-4">
  <Image
    src={avatarImage}
    width={144}
    height={144}
    format="png"
    alt="Avatar"
    class="h-36 w-36"
  />
  <div class="flex flex-col">
    <h1 class="text-display-md md:text-display-xl mb-0 text-center w-72 mx-auto md:w-full">{t("homepage.title")}</h1>
    <span class="text-center text-gray-500 font-extralight italic">{t("homepage.job")}</span>
    <p class="text-justify mt-3">
      {t("homepage.description")}
    </p>
  </div>
</div>
