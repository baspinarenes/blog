---
import { Image } from "@astrojs/image/components";
import { t } from "i18next";
import avatarImage from "../assets/avatar.webp";
---

<div class="flex flex-col items-center gap-4 md:gap-10 md:flex-row-reverse md:items-start">
  <Image
    src={avatarImage}
    width={144}
    height={144}
    format="png"
    alt="Avatar"
    class="h-36 w-36 animate-scream"
  />
  <div class="flex flex-col text-center md:text-start">
    <h1 class="w-72 mx-auto md:w-full">{t("homepage.title")}</h1>
    <span class="text-gray-500">{t("homepage.job")}</span>
    <p class="text-justify mt-3">
      {t("homepage.description")}
    </p>
  </div>
</div>
