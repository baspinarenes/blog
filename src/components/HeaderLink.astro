---
interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const { pathname: currentPathname } = Astro.url;

const languagelessCurrentPathname = currentPathname.replace("en/", "");
const languagelessPathname = pathname.replace("en/", "");
const isActive =
  languagelessPathname === "/"
    ? languagelessCurrentPathname === languagelessPathname
    : languagelessCurrentPathname.includes(languagelessPathname);
---

<a
  class:list={[
    "block px-6 py-4 rounded-md text-md text-gray-500 hover:bg-gray-200 translation-all sm:px-4 sm:py-2",
    { "font-bold !text-[#000]": isActive },
  ]}
  href={pathname}
>
  <slot />
</a>
