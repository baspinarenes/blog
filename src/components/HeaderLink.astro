---
interface Props {
  href: string;
}

const { href } = Astro.props;
const { pathname } = Astro.url;

console.log(href);
console.log(pathname);
const isActive = href === "/" ? pathname === href : pathname.includes(href);
---

<a
  class:list={[
    "block px-6 py-4 rounded-md text-md text-gray-500 hover:bg-gray-200 translation-all sm:px-4 sm:py-2",
    { "font-bold !text-[#000]": isActive },
  ]}
  href={href}
>
  <slot />
</a>
