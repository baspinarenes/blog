---
import i18next from "i18next";

export interface Props {
  date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(i18next.language === "tr" ? "tr-TR" : "en-us", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  }
</time>
