---
import { t } from "i18next";

const today = new Date();
const { className } = Astro.props;
---

<footer
  class={`flex flex-col mt-auto pt-12 md:pt-16 mb-2 text-center text-gray-600 text-xs md:flex-row md:gap-1 md:justify-center ${
    className ?? ""
  }`}
>
  {today.getFullYear()}{t("site.copyright_1")}
  <span>{t("site.copyright_2")}</span>
<span> Thanks 
  <a href="https://icons8.com/icon/20940/edvard-munch" class="text-green">
   icons8
  </a> for the avatar.
</span>
</footer>
