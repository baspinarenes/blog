---
import { Image } from "@astrojs/image/components";
import '@fontsource/jetbrains-mono';
import type { CollectionEntry } from "astro:content";
import i18next from "i18next";
import avatarImage from "../assets/avatar.webp";
import Toc from "../components/Toc.astro";
import { PROFILE } from "../consts";
import type { Heading } from "../models/interfaces/common";
import Layout from "./Layout.astro";

type Props = CollectionEntry<"blog">["data"] | {headings: Heading[]};

const dateOptions: object = {
  year: "numeric",
  month: "short",
  day: "numeric",
};

const { title, description, pubDate, updatedDate, heroImage, supTitle, tags, minutesRead, headings } = Astro.props;
---

<Layout>
  <main class="flex">
    <article class="relative w-full">
      <div class="flex flex-col mb-16">
        {supTitle && <h3 class="mb-0 text-lg font-normal">{supTitle}</h3>}
        <h1 class="mb-5">{title}</h1>
        <div class="flex justify-between items-center">
          <div class="flex items-center gap-2">
            <Image
              src={avatarImage}
              width={24}
              height={24}
              format="png"
              alt="Writer avatar"
              class="h-6 w-6 border-none"
            />
            <div class="text-sm">
              {PROFILE.NAME} / {new Date(pubDate).toLocaleDateString(i18next.language ? "tr-TR" : "en-US", dateOptions)}
            </div>
          </div>
          <div class="text-sm">
            {minutesRead}
          </div>
        </div>
      </div>
      <slot />
    </article>
    <Toc headings={headings} />
  </main>
</Layout>

<style is:global lang="scss">
  article {
    @apply text-sm sm:text-md;

    * {      
      -ms-overflow-style: none;  /* Internet Explorer 10+ */
      scrollbar-width: none;  /* Firefox */

      &::-webkit-scrollbar { 
        display: none;  /* Safari and Chrome */
      }
    }

    h2 {
      @apply mt-12 md:mt-20 mb-6;
    }

    h3 {
      @apply mt-10 md:mt-14 mb-4
    }

    a {
      @apply text-blue font-medium hover:brightness-50 break-all;
    }

    iframe {
      @apply mb-6 mx-auto w-full aspect-video rounded-lg;
    }

    ul {
      @apply -mt-3 mb-8;

      li {
        &::before {
          @apply h-[5px] w-[5px] inline-block bg-gray-600 align-middle rounded-full mr-2;

          content: ""
        }
      }
    }

    & > p {
      @apply mb-6;
    }

    p:has(img) {
      @apply -mx-6;

      img {
        @apply w-full md:rounded-lg;
      }
    }

    code, pre {
      font-family: "Jetbrains Mono";
    }

    code:not([data-language]) {
      @apply rounded-md text-sm p-1 text-orange;
    }

    pre:not([data-language]) {
      @apply bg-black text-gray-500 -mx-6 -mt-8 mb-6 px-6 pb-3 border-gray-700 overflow-x-scroll text-sm grid  md:rounded-b-lg;

      &:before {
        @apply block text-xs font-bold mb-2 uppercase font-mono;

        content: "Output:";
      }

      code {
        @apply text-gray-500 p-0;
      }
    }

    div[data-rehype-pretty-code-fragment] {
      @apply mb-6 -mx-6 overflow-hidden md:rounded-md;

      pre {
        @apply py-8 overflow-x-scroll grid text-sm;

        background-color: #101828 !important;

        code {
          @apply grid;

          &:not([data-line-numbers]) {
            .line {
              @apply pl-6;
            }
          }

          .highlighted {
            background-color: rgba(255, 255, 255, 0.1);
          }

          .word {
            @apply p-1 rounded-md;
          }

          .line {
            @apply px-4;

            &::before {

              /* Other styling */
              display: inline-block;
              width: 1rem;
              margin-right: 1rem;
              text-align: right;
              color: gray;
            }
          }

          &[data-line-numbers] {
            counter-reset: lineNumber;

            .line::before {
            counter-increment: lineNumber;
            content: counter(lineNumber);
            display: inline-block;
            text-align: right;

            /* stylistic preferences */
            margin-right: 0.75rem;
            width: 1rem;
            color: rgb(255 255 255 / 0.2);
          }
          }
        }
      }
    }

    span[data-rehype-pretty-code-fragment] {
      code {
        @apply rounded-md text-sm p-1;
      }
    }

    div[data-rehype-pretty-code-title] {
      @apply bg-black text-gray-400 px-4 py-2 border-b border-gray-700;

      & + pre {
        background-color: #101828 !important;
      }
    }
  }
</style>
